{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignore": [
    "packages/web/public/sound-worklet.js",
    "packages/engine/src/m68k/cycle-table.ts",
    "packages/engine/src/m68k/sub-cycle-costs.ts",
    "packages/engine/src/audio/ym2151-tables.ts",
    "packages/engine/src/audio/ym2151-envelope.ts",
    "packages/engine/src/m6502/sound-clock.ts"
  ],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "duplicates": "off"
  },
  "workspaces": {
    ".": {
      "entry": ["oracle/**/*.ts", "harness/**/*.ts"],
      "project": ["oracle/**/*.ts", "harness/**/*.ts"]
    },
    "packages/engine": { "entry": ["test/**/*.test.ts"] },
    "packages/web": { "entry": ["test/**/*.test.ts"] },
    "packages/cli": { "entry": ["src/*.ts"] }
  }
}
